{
  "name": "@blueprint-ts/core",
  "version": "4.1.0-beta.6",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./pagination": {
      "types": "./dist/pagination/index.d.ts",
      "import": "./dist/pagination/index.js",
      "default": "./dist/pagination/index.js"
    },
    "./support": {
      "types": "./dist/support/index.d.ts",
      "import": "./dist/support/index.js",
      "default": "./dist/support/index.js"
    },
    "./requests": {
      "types": "./dist/requests/index.d.ts",
      "import": "./dist/requests/index.js",
      "default": "./dist/requests/index.js"
    },
    "./bulkRequests": {
      "types": "./dist/bulkRequests/index.d.ts",
      "import": "./dist/bulkRequests/index.js",
      "default": "./dist/bulkRequests/index.js"
    },
    "./persistenceDrivers": {
      "types": "./dist/persistenceDrivers/index.d.ts",
      "import": "./dist/persistenceDrivers/index.js",
      "default": "./dist/persistenceDrivers/index.js"
    },
    "./requests/exceptions": {
      "types": "./dist/requests/exceptions/index.d.ts",
      "import": "./dist/requests/exceptions/index.js",
      "default": "./dist/requests/exceptions/index.js"
    },
    "./laravel/requests": {
      "types": "./dist/laravel/requests/index.d.ts",
      "import": "./dist/laravel/requests/index.js",
      "default": "./dist/laravel/requests/index.js"
    },
    "./laravel/pagination": {
      "types": "./dist/laravel/pagination/index.d.ts",
      "import": "./dist/laravel/pagination/index.js",
      "default": "./dist/laravel/pagination/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "default": "./dist/vue/index.js"
    },
    "./vue/forms": {
      "types": "./dist/vue/forms/index.d.ts",
      "import": "./dist/vue/forms/index.js",
      "default": "./dist/vue/forms/index.js"
    },
    "./vue/forms/validation": {
      "types": "./dist/vue/forms/validation/index.d.ts",
      "import": "./dist/vue/forms/validation/index.js",
      "default": "./dist/vue/forms/validation/index.js"
    },
    "./vue/requests": {
      "types": "./dist/vue/requests/index.d.ts",
      "import": "./dist/vue/requests/index.js",
      "default": "./dist/vue/requests/index.js"
    },
    "./vue/router/routeResourceBinding": {
      "types": "./dist/vue/router/routeResourceBinding/index.d.ts",
      "import": "./dist/vue/router/routeResourceBinding/index.js",
      "default": "./dist/vue/router/routeResourceBinding/index.js"
    },
    "./vue/state": {
      "types": "./dist/vue/state/index.d.ts",
      "import": "./dist/vue/state/index.js",
      "default": "./dist/vue/state/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build:package \"build-only {@}\" --",
    "build:package": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build-only": "vite build",
    "lint": "eslint \"src/**/*.{js,vue,ts}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue,ts}\" --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "type-check": "tsc --noEmit",
    "type-check:consumer-fixture": "npx --yes -p typescript@5.4.5 tsc -p ./tests/fixtures/consumer/tsconfig.json --pretty false",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "npm run build:package"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node20": "^20.1.2",
    "@types/jsdom": "^21.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.28",
    "@types/qs": "^6.9.18",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@typescript-eslint/typescript-estree": "^8.21.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vitest/coverage-v8": "^3.0.4",
    "@vue/eslint-config-typescript": "^14.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.31.0",
    "jsdom": "^24.0.0",
    "npm-run-all2": "^6.1.2",
    "prettier": "^3.0.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vite": "^5.1.6",
    "vitepress": "^1.6.3",
    "vitest": "^3.0.4",
    "vue": "^3.4.25",
    "vue-router": "^4.3.2"
  },
  "dependencies": {
    "lodash-es": "^4.17.23",
    "qs": "^6.15.0",
    "uuid": "^13.0.0"
  }
}
