{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*"],
  "compilerOptions": {
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  }
}